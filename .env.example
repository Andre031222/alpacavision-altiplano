# AlpacaVision AI — Variables de entorno (copiar a .env y completar)
# NO subir el archivo .env al repositorio

# ── Groq (LLM para reportes veterinarios) ────────────────────────────────────
# Obtener gratis en: https://console.groq.com
GROQ_API_KEY=pegar_aqui_tu_groq_api_key

# ── Roboflow ──────────────────────────────────────────────────────────────────
ROBOFLOW_API_KEY=pegar_aqui_tu_api_key

# ── Kaggle ────────────────────────────────────────────────────────────────────
# Alternativa a kaggle.json: definir directamente aquí
KAGGLE_USERNAME=tu_usuario_kaggle
KAGGLE_KEY=tu_api_key_kaggle

# ── iNaturalist ──────────────────────────────────────────────────────────────
# No requiere API key para consultas públicas de lectura

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
